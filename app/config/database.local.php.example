/**
 * Database credentials — SERVER-SPECIFIC, NEVER COMMITTED.
 *
 * Copy this file to  app/config/database.local.php  on each environment
 * and fill in the real values. It is git-ignored, so it is never pushed
 * to the repo and never overwritten by a git deployment.
 *
 * Production (OVH) values go here on the server.
 */

define('DB_HOST', 'xxxxx.mysql.db');   // OVH database server/host
define('DB_PORT', '3306');
define('DB_NAME', 'your_db_name');
define('DB_USER', 'your_db_user');
define('DB_PASS', 'your_db_password');
define('DB_CHARSET', 'utf8mb4');
