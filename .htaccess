# SEPJ Gabès - Root .htaccess
# Security: Block direct access to sensitive directories

# Disable directory listing
Options -Indexes

# Block access to app directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Block direct access to /app
    RewriteRule ^app/ - [F,L]
    
    # Block direct access to /database
    RewriteRule ^database/ - [F,L]
    
    # Block direct access to /install (except check.php)
    RewriteRule ^install/ - [F,L]
    
    # Block access to .sql, .md, .log files
    RewriteRule \.(sql|md|log)$ - [F,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Restrict access to browser features not used by this app
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Content-Security-Policy
    # Tailwind CDN (script), Font Awesome CDN (styles + fonts), YouTube embeds (frames)
    # 'unsafe-inline' for styles is required by Tailwind CDN's runtime injection
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; font-src 'self' https://cdnjs.cloudflare.com; img-src 'self' data: blob:; frame-src https://www.youtube.com; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self';"

    # HSTS — active for production (sepjgabes.tn with HTTPS confirmed)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# PHP settings
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log logs/php-error.log
</IfModule>